<Window x:Class="Chatbot.tasks"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="600" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="#1C1085">

    <Window.Resources>
        <Style x:Key="CyberBtn" TargetType="Button">
            <Setter Property="Background" Value="green"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2255AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2255AA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AACCFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0E0869" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Task Manager" FontFamily="Segoe UI Black"
                           FontSize="22" Foreground="White"/>
                <TextBlock Text="Manage your cybersecurity tasks"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#AACCFF"/>
            </StackPanel>
        </Border>

        <!-- Add Task Form -->
        <Border Grid.Row="1" Background="#0E0869" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Task Name"
                           Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Description"
                           Style="{StaticResource LabelStyle}" Margin="8,8,0,3"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Reminder Date (YYYY-MM-DD)"
                           Style="{StaticResource LabelStyle}" Margin="8,8,0,3"/>

                <TextBox Grid.Row="1" Grid.Column="0" x:Name="txt_taskName"
                         Style="{StaticResource InputStyle}" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txt_description"
                         Style="{StaticResource InputStyle}" Margin="8,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="txt_date"
                         Style="{StaticResource InputStyle}" Margin="8,0,8,0"/>
                <Button Grid.Row="1" Grid.Column="3" Content="Add Task"
                        Style="{StaticResource CyberBtn}" Width="100"
                        Click="AddTask_Click" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Task List  styles universal -->
        <Border Grid.Row="2" Background="#0E0869" CornerRadius="8" Padding="8">
            <DataGrid x:Name="tasks_grid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Background="#0E0869"
                      Foreground="White"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1A3A5C"
                      RowBackground="#0D1B2A"
                      AlternatingRowBackground="#112233"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow" SelectionChanged="tasks_grid_SelectionChanged">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A3A5C"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding TaskId}"      Width="50"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Task Name"   Binding="{Binding TaskName}"    Width="180" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Due Date"    Binding="{Binding TaskDate}"    Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Status"      Binding="{Binding TaskStatus}"  Width="100" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content=" Completed" Style="{StaticResource CyberBtn}"
                    Width="140" Margin="0,0,10,0" Click="Complete_Click"
                    Background="#00C94B"/>
            <Button Content="Delete Task" Style="{StaticResource CyberBtn}"
                    Width="120" Margin="0,0,10,0" Click="Delete_Click"
                    Background="#8B0000"/>
            <Button Content="Refresh" Style="{StaticResource CyberBtn}"
                    Width="100" Click="Refresh_Click"
                     Background="#000000"/>
        </StackPanel>
    </Grid>
</Window>
