<Window x:Class="Chatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot AI" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="white">

    <Window.Resources>
        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2255AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- HOME GRID -->
        <Grid x:Name="home_grid" Visibility="Visible" Margin="0,5,0,5" HorizontalAlignment="Center" Width="880">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="3"
                       FontFamily="Courier New" FontSize="13" Foreground="#1A3A5C"
                       HorizontalAlignment="Center" Margin="0,138,0,-169"
                       xml:space="preserve" Text="&#xA;   ____      _               ____        _&#xA;  / ___|   _| |__   ___ _ __| __ )  ___ | |_&#xA; | |  | | | | '_ \ / _ \ '__|  _ \ / _ \| __|&#xA; | |__| |_| | |_) |  __/ |  | |_) | (_) | |_&#xA;  \____\__, |_.__/ \___|_|  |____/ \___/ \__|&#xA;       |___/&#xA;   Cybersecurity Awareness Bot&#xA;"/>

            <TextBlock Grid.Row="3" Text="Welcome to CyberBot AI"
                       FontFamily="Segoe UI Light" FontSize="26"
                       Foreground="#1A3A5C" HorizontalAlignment="Center"
                       Margin="0,94,0,-27"/>

            <TextBlock Grid.Row="3" Text="Your cybersecurity awareness companion"
                       FontFamily="Segoe UI" FontSize="13" Foreground="#557799"
                       HorizontalAlignment="Center" Margin="0,289,0,-264"/>

            <Button Grid.Row="3" Content="Proceed"
                    Style="{StaticResource CyberButton}"
                    Height="44" Width="200" HorizontalAlignment="Left"
                    Click="proceed" Margin="332,338,0,-280"/>
        </Grid>

        <!-- USERNAME GRID -->
        <Grid x:Name="username_grid" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontFamily="Courier New" FontSize="13"
                       Foreground="#1A3A5C" HorizontalAlignment="Center"
                       Margin="0,20,0,0" xml:space="preserve">
   ____      _               ____        _
  / ___|   _| |__   ___ _ __| __ )  ___ | |_
 | |  | | | | '_ \ / _ \ '__|  _ \ / _ \| __|
 | |__| |_| | |_) |  __/ |  | |_) | (_) | |_
  \____\__, |_.__/ \___|_|  |____/ \___/ \__|
       |___/
   Cybersecurity Awareness Bot
            </TextBlock>

            <TextBlock Grid.Row="1" Text="Enter your username to continue"
                       FontFamily="Segoe UI Light" FontSize="20"
                       Foreground="#1A3A5C" HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>

            <TextBox Grid.Row="2" x:Name="username_input"
                     Height="40" Width="300" HorizontalAlignment="Center"
                     Margin="0,0,0,6" FontSize="14" Padding="8,6"/>

            <TextBlock Grid.Row="3" x:Name="username_error"
                       Text="Please enter a username to continue."
                       Foreground="Red" FontSize="12"
                       HorizontalAlignment="Center"
                       Visibility="Hidden" Margin="0,0,0,10"/>

            <Button Grid.Row="4" Content="Submit Username"
                    Style="{StaticResource CyberButton}"
                    Height="44" Width="200"
                    HorizontalAlignment="Center"
                    Click="submit_name"/>
        </Grid>

        <!-- CHAT GRID -->
        <Grid x:Name="chat_grid" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with Tasks and Quiz buttons -->
            <Border Grid.Row="0" Background="#1A3A5C" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CyberBot AI"
                                   FontFamily="Segoe UI Black"
                                   FontSize="20" Foreground="White"/>
                        <TextBlock x:Name="header_username"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="16" Foreground="#AACCFF"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="My Tasks"
                            Height="40" Width="110"
                            Background="#1A5C3A"
                            Foreground="White"
                            FontFamily="Segoe UI Semibold"
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            Click="open_tasks"
                            VerticalAlignment="Center"/>

                    <Button Grid.Column="2"
                            Content="Quiz"
                            Height="40" Width="90"
                            Background="#5C1A5C"
                            Foreground="White"
                            FontFamily="Segoe UI Semibold"
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="open_quiz"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Chat messages -->
            <ScrollViewer Grid.Row="1" x:Name="chat_scroll"
                          VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel x:Name="chat_panel"/>
            </ScrollViewer>

            <!-- Input area -->
            <Border Grid.Row="2" Background="#C8DFF0" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="question"
                             Height="44" Margin="0,0,10,0"
                             FontSize="13" Padding="8,6"
                             VerticalContentAlignment="Center"
                             KeyDown="question_KeyDown"/>

                    <Button Grid.Column="1" Content="Send"
                            Style="{StaticResource CyberButton}"
                            Height="44" Width="90"
                            Margin="0,0,8,0" Click="send"/>

                    <Button Grid.Column="2" Content="Exit"
                            Height="44" Width="90"
                            Background="#8B0000"
                            Foreground="White"
                            FontFamily="Segoe UI Semibold"
                            FontSize="14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="exit_click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
