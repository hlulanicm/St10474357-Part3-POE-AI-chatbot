<Window x:Class="Chatbot.quiz"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot Quiz" Height="650" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="white">

    <Window.Resources>
        <Style x:Key="QuizBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2255AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="77*"/>
            <ColumnDefinition Width="157*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="65.04"/>
            <RowDefinition Height="20.183"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="343*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E3CA3" CornerRadius="8" Padding="16,12" Margin="0,0,0,16" Grid.RowSpan="2" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cybersecurity Quiz" FontFamily="Segoe UI Black"
                               FontSize="22" Foreground="White"/>
                    <TextBlock Text="Test your cybersecurity knowledge!"
                               FontFamily="Segoe UI" FontSize="12" Foreground="#AACCFF"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="lbl_score" Text="Score: 0"
                               FontFamily="Segoe UI Black" FontSize="20"
                               Foreground="#FFD700" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="lbl_progress" Text="Question 1 of 10"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#AACCFF" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2" x:Name="progress_bar"
                     Height="8" Minimum="0" Maximum="10" Value="0"
                     Background="#112233" Foreground="#2255AA"
                     Margin="0,23,0,38" BorderThickness="0" Grid.ColumnSpan="2"/>

        <!-- Question -->
        <Border Grid.Row="2" Background="#112233" CornerRadius="8" Padding="20,16" Margin="0,24,0,12" Grid.RowSpan="2" Grid.ColumnSpan="2">
            <TextBlock x:Name="lbl_question"
                       Text="Loading question..."
                       FontFamily="Segoe UI Semibold"
                       FontSize="16"
                       Foreground="White"
                       TextWrapping="Wrap"
                       LineHeight="24"/>
        </Border>

        <!-- Answer Buttons -->
        <StackPanel Grid.Row="4" x:Name="answers_panel" Margin="0,22,0,0" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Button x:Name="btn_a" Style="{StaticResource QuizBtn}" Click="Answer_Click" Tag="0"/>
            <Button x:Name="btn_b" Style="{StaticResource QuizBtn}" Click="Answer_Click" Tag="1"/>
            <Button x:Name="btn_c" Style="{StaticResource QuizBtn}" Click="Answer_Click" Tag="2"/>
            <Button x:Name="btn_d" Style="{StaticResource QuizBtn}" Click="Answer_Click" Tag="3"/>
        </StackPanel>

        <!-- Feedback -->
        <Border Grid.Row="6" x:Name="feedback_border" CornerRadius="8"
                Padding="16,10" Margin="0,12,0,-12" Visibility="Collapsed" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <TextBlock x:Name="lbl_feedback"
                       FontFamily="Segoe UI Semibold"
                       FontSize="14"
                       Foreground="White"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Next Button -->
        <Button Grid.Row="7" x:Name="btn_next"
                Content="Next Question"
                Style="{StaticResource QuizBtn}"
                Background="#1A5C3A"
                Width="200"
                HorizontalAlignment="Right"
                Margin="0,12,0,-60"
                Visibility="Collapsed"
                Click="Next_Click" Grid.Column="1"/>
    </Grid>
</Window>
